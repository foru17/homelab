# Copy to config.env and fill in. config.env is YOURS — keep it out of git.
# Nothing here ships with real values; every field is a placeholder.

# --- target VPS ---
SERVER_IP="203.0.113.10"                       # public IPv4
SERVER_IPV6="2001:db8::10"                      # public IPv6 (optional; leave empty to skip AAAA)
SSH_USER="root"                                 # root, or a sudo user (scripts escalate via sudo)
SSH_KEY="$HOME/.ssh/your-vps-key.pem"           # private key for the VPS
TZ="UTC"                                          # server timezone (e.g. UTC, Asia/Shanghai, America/Los_Angeles)

# --- domain (Cloudflare-managed) ---
PARENT_ZONE="example.com"                        # the zone in your Cloudflare account
DOMAIN_ROOT="nodeA.example.com"                  # this node owns *.nodeA.example.com
CF_API_TOKEN="cf-token-with-Zone-DNS-Edit"       # scoped token; NEVER commit
CF_ZONE_ID=""                                    # optional; 02-cf-dns.py looks it up if empty

# --- subdomain labels (CHOOSE YOUR OWN, NON-OBVIOUS ONES) ---
# Your panels sit at <SUB_*>.<DOMAIN_ROOT>. If your zone is public, do NOT reuse an
# obvious convention (a label that names the service it fronts) — anyone can then
# enumerate your control planes from DNS. Pick random-ish labels and keep them to
# yourself. These examples are neutral placeholders, deliberately NOT a real scheme.
SUB_PANEL="console"                              # aaPanel        -> console.<root>
SUB_XUI="gateway"                                # 3x-ui panel    -> gateway.<root>
SUB_COVER="edge"                                 # node cover     -> edge.<root>
# landing page uses the bare <DOMAIN_ROOT>.

# --- aaPanel ---
AAPANEL_USER="admin_you"
AAPANEL_ENTRANCE="/change-this-entrance"         # secret path, e.g. /8f3a1c
AAPANEL_PORT=""                                  # leave EMPTY — the installer assigns a random port;
                                                 # scripts read it from the box (/www/server/panel/data/port.pl).
                                                 # Only set this to force a specific value.
AAPANEL_PASS=""                                  # generate at runtime; store in password manager

# --- 3x-ui ---
XUI_USER="panel_you"
XUI_PATH="/change-this-path/"                     # webBasePath, trailing slash
XUI_PORT="14533"                                  # panel listen 127.0.0.1:XUI_PORT
XUI_PASS=""                                        # generate at runtime; store in password manager
XUI_UUID=""                                         # generate at runtime (uuidgen); inbound auth id
XUI_SUBID=""                                         # generate at runtime; subscription id

# --- inbound ports (behind nginx on 127.0.0.1) ---
PORT_DIRECT="57707"                                 # direct-egress inbound (SERVER_IP)
PORT_WARP="57708"                                   # WARP-egress inbound
WARP_SOCKS_PORT="40000"                             # cloudflare-warp proxy SOCKS5 port

# --- WS cover paths (CHOOSE YOUR OWN, NON-OBVIOUS ONES) ---
# These are the public URL paths that carry the tunnel. On a public domain they are part
# of your disguise — do NOT reuse someone else's convention or publish yours, or they can
# be probed/fingerprinted. Make them look like ordinary web paths, unique to you.
# These examples are neutral placeholders, deliberately NOT a real scheme.
WS_PATH_DIRECT="/assets"                             # direct-egress cover path
WS_PATH_WARP="/media"                                # WARP-egress cover path

# --- monitoring (optional; leave empty to skip) ---
NEZHA_SERVER=""                                     # e.g. report.example.com:8966
NEZHA_TLS="false"
NEZHA_SECRET=""                                     # shared agent key for your Nezha panel
NEZHA_UUID=""                                        # generate at runtime
KOMARI_ENDPOINT=""                                  # e.g. https://komari.example.com
KOMARI_DISCOVERY_KEY=""                              # auto-discovery key for your Komari panel

# --- node display name (monitoring / labels) ---
NODE_NAME="Edge Node A"
